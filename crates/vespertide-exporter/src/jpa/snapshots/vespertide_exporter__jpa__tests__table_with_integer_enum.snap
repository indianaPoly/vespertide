import jakarta.persistence.*;

enum PriorityLevel {
    LOW(0),
    MEDIUM(10),
    HIGH(20);

    private final int value;

    PriorityLevel(int value) {
        this.value = value;
    }

    public int getValue() {
        return value;
    }
}

@Entity
@Table(name = "tasks")
public class Tasks {

    @Id
    @Column(name = "id")
    private Integer id;

    @Column(name = "priority", nullable = false)
    private Integer priority;

    protected Tasks() {
    }
}
