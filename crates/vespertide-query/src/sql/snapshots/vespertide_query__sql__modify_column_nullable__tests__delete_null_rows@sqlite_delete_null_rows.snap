source: crates/vespertide-query/src/sql/modify_column_nullable.rs
expression: sql
---
DELETE FROM "orders" WHERE "user_id" IS NULL
CREATE TABLE "orders_temp" ( "id" integer NOT NULL, "user_id" integer NOT NULL )
INSERT INTO "orders_temp" ("id", "user_id") SELECT "id", "user_id" FROM "orders"
DROP TABLE "orders"
ALTER TABLE "orders_temp" RENAME TO "orders"
